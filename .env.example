# ============================================
# Configuracoes da aplicacao
# ============================================

# Perfil ativo do Spring Boot (dev, prod, rag)
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Ollama - Modelo LLM local
# ============================================

# URL base do servidor Ollama (mapeia para rag.ollama.url)
RAG_OLLAMA_URL=http://localhost:11434

# Modelo LLM para geracao de respostas
OLLAMA_MODEL=gemma3:4b

# Modelo para geracao de embeddings
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================
# AI Agent - Assistente Marvel
# ============================================

# Ativar/desativar o agente de IA
AI_AGENT_ENABLED=true

# Temperatura do modelo (0.0 a 1.0)
AI_AGENT_TEMPERATURE=0.7

# Maximo de tokens por resposta
AI_AGENT_MAX_TOKENS=4096

# ============================================
# Chunking - Divisao de documentos
# ============================================

# Tamanho do chunk em caracteres
CHUNK_SIZE=1000

# Overlap entre chunks consecutivos
CHUNK_OVERLAP=150

# ============================================
# Marvel API - Dados Oficiais
# ============================================

# Marvel Developer API keys (https://developer.marvel.com)
MARVEL_API_PUBLIC_KEY=sua_public_key_aqui
MARVEL_API_PRIVATE_KEY=sua_private_key_aqui

# ============================================
# n8n - Webhook de automacao
# ============================================

# URL do webhook do n8n (deixe vazio se nao usar)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ingestion-complete

# Ativar envio de webhook apos ingestao
N8N_WEBHOOK_ENABLED=true
