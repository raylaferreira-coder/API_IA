# Perfil ativo (dev, rag, prod)
SPRING_PROFILES_ACTIVE=dev

# Conexao com o banco (preenchido pelo dev de infra)
DATABASE_URL=jdbc:postgresql://localhost:5432/chatdb
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ingestion-complete

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# AI Agent
AI_AGENT_ENABLED=true
AI_AGENT_TEMPERATURE=0.7
AI_AGENT_MAX_TOKENS=2048
